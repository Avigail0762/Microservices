{
  "Jwt": {
    "Key": "SuperSecretKeyForSaleApp1234567890!!",
    "Issuer": "SaleApp",
    "Audience": "SaleAppUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "order-service",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "customer-register": {
        "ClusterId": "order-service",
        "Match": { "Path": "/api/customer/register" }
      },
      "customer-gifts": {
        "ClusterId": "order-service",
        "Match": { "Path": "/api/customer/gifts" }
      },
      "customer-protected": {
        "ClusterId": "order-service",
        "Match": { "Path": "/api/customer/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "inventory": {
        "ClusterId": "inventory-service",
        "Match": { "Path": "/api/inventory/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "lottery": {
        "ClusterId": "inventory-service",
        "Match": { "Path": "/api/lottery/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "purchases": {
        "ClusterId": "inventory-service",
        "Match": { "Path": "/api/purchases/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "gift-public": {
        "ClusterId": "catalog-service",
        "Match": { "Path": "/api/gift" }
      },
      "gift-public-subpaths": {
        "ClusterId": "catalog-service",
        "Match": { "Path": "/api/gift/{**catch-all}" }
      },
      "donor": {
        "ClusterId": "catalog-service",
        "Match": { "Path": "/api/donor/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notification": {
        "ClusterId": "notification-service",
        "Match": { "Path": "/api/notification/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "bff": {
        "ClusterId": "bff-service",
        "Match": { "Path": "/api/bff/{**catch-all}" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "order-service": {
        "Destinations": {
          "order1": { "Address": "http://order-service:8080/" }
        }
      },
      "inventory-service": {
        "Destinations": {
          "inventory1": { "Address": "http://inventory-service:8083" }
        }
      },
      "catalog-service": {
        "Destinations": {
          "catalog-1": { "Address": "http://product-catalog-service:8081" }
        }
      },
      "notification-service": {
        "Destinations": {
          "notification1": { "Address": "http://notification-service:8084" }
        }
      },
      "bff-service": {
        "Destinations": {
          "bff1": { "Address": "http://bff-service:8090" }
        }
      }
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Service": "GatewayService"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
